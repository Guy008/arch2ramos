#!/bin/ash
# arch2ramos - Batocera from RAM boot script
#
# Batocera stores its OS as a squashfs file inside a FAT32 partition
# inside a .img file. This script:
#   1. Mounts the partition containing batocera.img
#   2. loop-mounts the FAT32 partition inside the image (offset=1048576)
#   3. Mounts the squashfs from that partition
#   4. Sets up overlayfs (writes go to RAM tmpfs)
#   5. switch_root into Batocera

# --- CONFIGURATION (patched by arch2ram-install) ---
IMG_SRC_DEV="REPLACE_WITH_HOME_DEV"
IMG_SRC_FSTYPE="btrfs"
IMG_FILE="REPLACE_WITH_IMG_FILE"

# Partition layout inside batocera.img (Batocera v42):
#   Part 1 (FAT32/BATOCERA): sector 2048,      size 10G  → offset = 2048*512 = 1048576
#   Part 2 (ext4/userdata):  sector 20973568,  size 512M → offset = 20973568*512 = 10738466816
FAT_OFFSET="1048576"
USERDATA_OFFSET="10738466816"

OVERLAY_SIZE="512M"
# --- END CONFIGURATION ---

fail() {
    echo ""
    echo "!!! Batocera RAM boot failed: $1"
    echo "!!! Dropping to emergency shell"
    exec /bin/ash
}

echo ""
echo "=== arch2ramos: booting Batocera from RAM ==="
echo ""

mount -t proc  proc  /proc  || fail "proc"
mount -t sysfs sysfs /sys   || fail "sysfs"
mount -t devtmpfs dev /dev  || fail "devtmpfs"

# Allow kernel cmdline to override config (useful for VM testing)
# e.g. pass: img_src_dev=/dev/vda img_src_fstype=ext4
for param in $(cat /proc/cmdline); do
    case "$param" in
        img_src_dev=*)      IMG_SRC_DEV="${param#img_src_dev=}" ;;
        img_src_fstype=*)   IMG_SRC_FSTYPE="${param#img_src_fstype=}" ;;
        img_file=*)         IMG_FILE="${param#img_file=}" ;;
    esac
done

echo "[0/6] Loading kernel modules..."
KVER=$(uname -r)
MODDIR="/lib/modules/${KVER}"
for MOD in loop fat vfat squashfs overlay; do
    insmod "${MODDIR}/${MOD}.ko" 2>/dev/null && echo "      ${MOD}: OK" || echo "      ${MOD}: already loaded or built-in"
done
# BLK_DEV_LOOP_MIN_COUNT=0: no static loop devices — use loop-control to allocate
mknod /dev/loop-control c 10 237 2>/dev/null || true
echo "      loop-control: $(ls -la /dev/loop-control 2>&1)"

echo "[1/6] Mounting source partition (${IMG_SRC_DEV})..."
# Try rw first (real machine: allows journal replay + rw loop devices for userdata)
# Fall back to ro,norecovery for VM testing (where drive is passed readonly)
mount -t ${IMG_SRC_FSTYPE} "${IMG_SRC_DEV}" /img_src 2>/dev/null || \
mount -o ro,norecovery -t ${IMG_SRC_FSTYPE} "${IMG_SRC_DEV}" /img_src 2>/dev/null || \
mount -o ro -t ${IMG_SRC_FSTYPE} "${IMG_SRC_DEV}" /img_src || fail "mount ${IMG_SRC_DEV} failed"
echo "    Looking for: /img_src${IMG_FILE}"
ls /img_src${IMG_FILE} >/dev/null 2>&1 && echo "    FILE FOUND" || { echo "    FILE NOT FOUND (ls /img_src):"; ls /img_src 2>&1; }

echo "[2/6] Setting up loop device on batocera.img (FAT partition at offset ${FAT_OFFSET})..."
echo "      img path: /img_src${IMG_FILE}"
echo "      img size: $(ls -lh /img_src${IMG_FILE} 2>&1)"
# Use losetup -f to let the kernel allocate a free loop device via loop-control
LOOP_DEV=$(losetup -f 2>/dev/null)
echo "      next free loop dev: ${LOOP_DEV}"
# devtmpfs won't auto-create the node without udevd — create it manually
if [ ! -e "${LOOP_DEV}" ]; then
    MINOR="${LOOP_DEV##*loop}"
    mknod "${LOOP_DEV}" b 7 "${MINOR}"
    echo "      created ${LOOP_DEV} (minor ${MINOR})"
fi
echo "      loop dev: $(ls -la ${LOOP_DEV} 2>&1)"
losetup -o ${FAT_OFFSET} "${LOOP_DEV}" /img_src${IMG_FILE} || fail "losetup on batocera.img"
echo "      losetup OK: ${LOOP_DEV}"

echo "[3/6] Mounting BATOCERA FAT partition (→ /boot)..."
# Mount rw so Batocera can write random seed, autoresize flag, etc.
mount -t vfat "${LOOP_DEV}" /boot_root 2>/dev/null || \
mount -o ro -t vfat "${LOOP_DEV}" /boot_root || fail "FAT BATOCERA mount"

# Also set up userdata (partition 2 of the .img) via a second loop device
LOOP_DEV2=$(losetup -f 2>/dev/null)
if [ ! -e "${LOOP_DEV2}" ]; then
    MINOR2="${LOOP_DEV2##*loop}"
    mknod "${LOOP_DEV2}" b 7 "${MINOR2}"
fi
losetup -o ${USERDATA_OFFSET} "${LOOP_DEV2}" /img_src${IMG_FILE} || fail "losetup userdata"
echo "      userdata loop: ${LOOP_DEV2}"

echo "[4/6] Mounting Batocera squashfs..."
mount -t squashfs -o ro /boot_root/boot/batocera /squash_base || fail "squashfs mount"

echo "[5/6] Setting up overlayfs (writes → RAM)..."
mount -t tmpfs -o size=${OVERLAY_SIZE} tmpfs /overlay_root || fail "overlay tmpfs"
mkdir -p /overlay_root/upper /overlay_root/work

mount -t overlay overlay \
    -o rw,lowerdir=/squash_base,upperdir=/overlay_root/upper,workdir=/overlay_root/work \
    /new_root || fail "overlayfs"

echo "[6/6] Moving mounts and switching to Batocera root..."
# Move /boot_root → /new_root/boot so Batocera can find batocera-boot.conf
mount --move /boot_root /new_root/boot   || fail "move /boot"
# Mount userdata partition → /new_root/userdata
mount -t ext4 "${LOOP_DEV2}" /new_root/userdata 2>/dev/null || \
    mount "${LOOP_DEV2}" /new_root/userdata 2>/dev/null || \
    echo "      WARNING: userdata mount failed, Batocera will use RAM"
mount --move /sys      /new_root/sys   2>/dev/null
mount --move /proc     /new_root/proc  2>/dev/null
mount --move /dev      /new_root/dev   2>/dev/null

# Unmount img_src — loop devices keep the file open via fd
umount /img_src 2>/dev/null || true

echo ""
echo "=== Switching to Batocera ==="
exec switch_root /new_root /sbin/init || fail "switch_root"
