#!/bin/bash
# arch2ram-create - build squashfs image from running Arch system
# Run this from your regular disk-based Arch installation
# Result: /arch-ram.sfs on your root partition

set -e

OUTPUT="/arch-ram.sfs"
OUTPUT_TMP="/arch-ram.sfs.tmp"
COMP="zstd"      # fast decompression = fast RAM boot
BLOCK="1M"

# Directories to exclude from the squashfs
EXCLUDES=(
    /proc
    /sys
    /dev
    /run
    /tmp
    /mnt
    /media
    /lost+found
    /arch-ram.sfs
    /arch-ram.sfs.tmp
    /home                       # keep home on disk
    /var/cache/pacman/pkg
    /var/log
    /var/tmp
    /opt/cuda                   # GPU toolkit — too large, not needed in RAM
    /opt/android-studio         # dev tool — not needed in RAM
    /usr/share/locale           # ~850MB, keep only what's needed
    /usr/share/doc              # documentation
    /usr/lib/debug              # debug symbols
)

if [[ $EUID -ne 0 ]]; then
    echo "Run as root: sudo arch2ram-create"
    exit 1
fi

if ! command -v mksquashfs &>/dev/null; then
    echo "Install squashfs-tools: sudo pacman -S squashfs-tools"
    exit 1
fi

echo "=== arch2ram-create ==="
echo "Output: ${OUTPUT}"
echo "Compression: ${COMP}"
echo ""

# Build exclude args
EXCL_ARGS=()
for dir in "${EXCLUDES[@]}"; do
    EXCL_ARGS+=(-e "$dir")
done

echo "Building squashfs (this takes a few minutes)..."
mksquashfs / "${OUTPUT_TMP}" \
    -comp "${COMP}" \
    -b "${BLOCK}" \
    -no-progress \
    "${EXCL_ARGS[@]}"

mv "${OUTPUT_TMP}" "${OUTPUT}"
echo ""
echo "Done! Size: $(du -sh ${OUTPUT} | cut -f1)"
echo "Run arch2ram-install to set up GRUB entry."
