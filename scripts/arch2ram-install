#!/bin/bash
# arch2ram-install - install initrd + GRUB entry
# Usage:
#   sudo arch2ram-install              → Arch from RAM
#   sudo arch2ram-install --batocera /path/to/batocera.img [UUID]

set -e

BOOT="/boot"
GRUB_CUSTOM="/etc/grub.d/40_custom"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
INITRD_SRC="${SCRIPT_DIR}/../initrd"

ALPINE_MINI="/tmp/arch2ramos-alpine-base.tar.gz"
ALPINE_URL="https://dl-cdn.alpinelinux.org/alpine/v3.21/releases/x86_64/alpine-minirootfs-3.21.3-x86_64.tar.gz"

MODE="arch"
BATOCERA_IMG=""
BATOCERA_HOME_UUID=""

if [[ "$1" == "--batocera" ]]; then
    MODE="batocera"
    BATOCERA_IMG="$2"
    BATOCERA_HOME_UUID="${3:-$(findmnt -n -o UUID /home)}"
fi

if [[ $EUID -ne 0 ]]; then
    echo "Run as root: sudo $0 $*"
    exit 1
fi

# ── helpers ──────────────────────────────────────────────────────────────────

build_initrd() {
    local INIT_SCRIPT="$1"
    local OUTPUT="$2"

    echo "[1/3] Getting Alpine musl busybox base..."
    if [[ ! -f "$ALPINE_MINI" ]]; then
        curl -sL -o "$ALPINE_MINI" "$ALPINE_URL"
    fi

    local BUILD="/tmp/arch2ramos-initrd-build"
    rm -rf "$BUILD"
    mkdir -p "$BUILD"
    tar -xzf "$ALPINE_MINI" -C "$BUILD" 2>/dev/null
    mkdir -p "$BUILD"/{img_src,boot_root,squash_base,overlay_root,new_root,proc,sys,dev,run}

    cp "$INIT_SCRIPT" "$BUILD/init"
    chmod 755 "$BUILD/init"

    echo "[2/3] Packing initrd..."
    (cd "$BUILD" && find . -print0 | cpio --null -o -H newc 2>/dev/null | gzip -9) > "$OUTPUT"
    echo "      → $OUTPUT ($(du -sh "$OUTPUT" | cut -f1))"
}

add_grub_entry() {
    local LABEL="$1"
    local INITRD_FILE="$2"

    # Remove old entry with same label if exists
    grep -v "$LABEL" "$GRUB_CUSTOM" > /tmp/grub_custom_tmp 2>/dev/null || true
    cp /tmp/grub_custom_tmp "$GRUB_CUSTOM" 2>/dev/null || true

    cat >> "$GRUB_CUSTOM" << GRUBEOF

menuentry "${LABEL}" --class gnu-linux --class os {
    insmod fat
    insmod part_gpt
    set root='hd0,gpt1'
    linux  /arch2ram-vmlinuz console=tty1 rdinit=/init quiet
    initrd /arch2ram-initrd-ucode.img /${INITRD_FILE}
}
GRUBEOF

    echo "[3/3] Regenerating GRUB..."
    grub-mkconfig -o /boot/grub/grub.cfg 2>/dev/null | grep -E "Found|Done|בוצע" || true
    echo "      → GRUB updated"
}

# ── copy kernel (shared) ─────────────────────────────────────────────────────

copy_kernel() {
    local KERNEL
    KERNEL=$(ls /boot/vmlinuz-linux-zen /boot/vmlinuz-linux 2>/dev/null | head -1)
    cp "$KERNEL" "${BOOT}/arch2ram-vmlinuz"

    # intel-ucode concatenated initrd
    if [[ -f "${BOOT}/intel-ucode.img" ]]; then
        cp "${BOOT}/intel-ucode.img" "${BOOT}/arch2ram-initrd-ucode.img"
    else
        # empty placeholder
        echo | cpio -o -H newc 2>/dev/null | gzip > "${BOOT}/arch2ram-initrd-ucode.img"
    fi
}

# ── MODE: arch ───────────────────────────────────────────────────────────────

if [[ "$MODE" == "arch" ]]; then
    ROOT_UUID=$(findmnt -n -o UUID /)
    echo "=== arch2ram-install: Arch from RAM ==="
    echo "Root UUID: ${ROOT_UUID}"
    echo ""

    INIT_TMP="/tmp/arch2ram-init-patched"
    sed "s|UUID=REPLACE_WITH_ROOT_UUID|UUID=${ROOT_UUID}|" \
        "${INITRD_SRC}/init" > "$INIT_TMP"
    chmod +x "$INIT_TMP"

    copy_kernel
    build_initrd "$INIT_TMP" "${BOOT}/arch2ram-initrd.gz"
    add_grub_entry "Arch Linux from RAM" "arch2ram-initrd.gz"

    echo ""
    echo "=== Done ==="
    echo "Next: sudo arch2ram-create   (build the squashfs, ~5 min)"
    echo "Then: reboot → 'Arch Linux from RAM'"
fi

# ── MODE: batocera ───────────────────────────────────────────────────────────

if [[ "$MODE" == "batocera" ]]; then
    if [[ -z "$BATOCERA_IMG" || ! -f "$BATOCERA_IMG" ]]; then
        echo "Error: batocera.img not found at: $BATOCERA_IMG"
        echo "Usage: sudo $0 --batocera /path/to/batocera.img"
        exit 1
    fi

    IMG_PATH="${BATOCERA_IMG}"
    IMG_DIR="$(dirname "$IMG_PATH")"
    IMG_FILE_ON_PARTITION="${IMG_PATH#/home}"

    echo "=== arch2ram-install: Batocera from RAM ==="
    echo "Image:     ${IMG_PATH}"
    echo "Home UUID: ${BATOCERA_HOME_UUID}"
    echo ""

    INIT_TMP="/tmp/batocera-init-patched"
    sed \
        -e "s|UUID=REPLACE_WITH_HOME_UUID|${BATOCERA_HOME_UUID}|" \
        -e "s|IMG_FILE=\"/Guy008/batocera-ram/batocera.img\"|IMG_FILE=\"${IMG_FILE_ON_PARTITION}\"|" \
        "${INITRD_SRC}/init-batocera" > "$INIT_TMP"
    chmod +x "$INIT_TMP"

    copy_kernel
    build_initrd "$INIT_TMP" "${BOOT}/batocera-ram-initrd.gz"
    add_grub_entry "Batocera from RAM" "batocera-ram-initrd.gz"

    echo ""
    echo "=== Done ==="
    echo "Reboot → 'Batocera from RAM'"
fi
