#!/bin/bash
# arch2ram-install - install initrd + GRUB entry
# Run once after clean install

set -e

BOOT="/boot"
GRUB_CUSTOM="/etc/grub.d/40_custom"
ROOT_UUID=$(findmnt -n -o UUID /)

if [[ $EUID -ne 0 ]]; then
    echo "Run as root: sudo arch2ram-install"
    exit 1
fi

echo "=== arch2ram-install ==="
echo "Root UUID: ${ROOT_UUID}"
echo ""

# Step 1: build the initrd
echo "[1/3] Building initrd..."
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
INITRD_SRC="${SCRIPT_DIR}/../initrd"

# Patch the UUID into the init script
sed "s/UUID=REPLACE_WITH_ROOT_UUID/UUID=${ROOT_UUID}/" \
    "${INITRD_SRC}/init" > /tmp/arch2ram-init
chmod +x /tmp/arch2ram-init

# Build initrd from Alpine minirootfs base (static musl busybox)
ALPINE_MINI="/arch2ramos-alpine-base.tar.gz"
if [[ ! -f "$ALPINE_MINI" ]]; then
    echo "Downloading Alpine minirootfs (static busybox)..."
    curl -L -o "$ALPINE_MINI" \
        "https://dl-cdn.alpinelinux.org/alpine/v3.21/releases/x86_64/alpine-minirootfs-3.21.3-x86_64.tar.gz"
fi

INITRD_BUILD="/tmp/arch2ramos-initrd-build"
rm -rf "$INITRD_BUILD"
mkdir -p "$INITRD_BUILD"/{boot_root,new_root,overlay_root,squash_base,img_src,proc,sys,dev}
tar -xzf "$ALPINE_MINI" -C "$INITRD_BUILD" 2>/dev/null
cp /tmp/arch2ram-init "$INITRD_BUILD/init"

(cd "$INITRD_BUILD" && find . -print0 | cpio --null -o -H newc 2>/dev/null | gzip -9) \
    > "${BOOT}/arch2ram-initrd.gz"

echo "    → ${BOOT}/arch2ram-initrd.gz ($(du -sh ${BOOT}/arch2ram-initrd.gz | cut -f1))"

# Step 2: copy kernel
echo "[2/3] Linking kernel..."
KERNEL=$(ls /boot/vmlinuz-linux-zen /boot/vmlinuz-linux 2>/dev/null | head -1)
cp "${KERNEL}" "${BOOT}/arch2ram-vmlinuz"
echo "    → ${BOOT}/arch2ram-vmlinuz"

# Step 3: add GRUB entry
echo "[3/3] Adding GRUB entry..."
cat >> "$GRUB_CUSTOM" << GRUBEOF

menuentry "Arch Linux from RAM" --class arch --class gnu-linux --class os {
    insmod fat
    insmod part_gpt
    set root='hd0,gpt1'
    echo "Loading Arch from RAM..."
    linux  /arch2ram-vmlinuz console=tty1 rdinit=/init quiet
    initrd /arch2ram-initrd.gz
}
GRUBEOF

grub-mkconfig -o /boot/grub/grub.cfg 2>/dev/null
echo "    → GRUB updated"

echo ""
echo "=== Install complete ==="
echo "Next: sudo arch2ram-create  (build the squashfs)"
echo "Then: reboot → select 'Arch Linux from RAM' in GRUB"
